font-family = FiraCode Nerd Font Mono Light
font-style = Regular
font-size = 13
font-thicken = true

cursor-style = block
cursor-style-blink = false

theme = catppuccin-mocha

# Mirror tmux mappings
keybind = ctrl+a>n=new_window
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>h=new_split:down
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>equal=equalize_splits

# LADR pane navigation
keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+j=goto_split:top
keybind = ctrl+k=goto_split:bottom
