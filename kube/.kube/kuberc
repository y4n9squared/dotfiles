apiVersion: kubectl.config.k8s.io/v1beta1
kind: Preference
defaults:
  - command: apply
    options:
      - name: server-side
        default: "true"
  - command: delete
    options:
      - name: interactive
        default: "true"
  - command: exec
    options:
      - name: it
aliases:
  - name: tail
    command: logs
    appendArgs:
      - --follow
      - --tail=50
  - name: po
    command: get
    appendArgs:
      - po
      - -o
      - go-template-file=/home/yang.yang/.kube/templates/get-pods.gotemplate
